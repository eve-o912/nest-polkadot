# Environment Variables for Nest Treasury
# Copy this file and fill in your actual values

# Privy Authentication (Required for wallet connection)
PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_SECRET=your_privy_app_secret_here

# Google Gemini AI (Required for AI agent functionality)
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# Neon Database (Required for data persistence)
NEON_DATABASE_URL=your_neon_database_url_here

# Upstash Redis (Optional for caching)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# Polkadot Network Configuration
POLKADOT_NETWORK=polkadotHub
POLKADOT_RPC_URL=https://rpc.polkadot.io

# Application Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CHAIN_ID=polkadot-hub
